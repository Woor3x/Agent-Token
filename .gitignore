# ============================================================================
# Agent-Token .gitignore
# ============================================================================

# ---- Python --------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
sdist/
wheels/
*.whl
pip-wheel-metadata/
share/python-wheels/
MANIFEST

# ---- Virtualenv ----------------------------------------------------------
.venv/
venv/
ENV/
env/
.env/

# ---- Test / coverage / lint cache ---------------------------------------
.pytest_cache/
pytest.ini
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# ---- Jupyter -------------------------------------------------------------
.ipynb_checkpoints/

# ---- IDE / editor --------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ---- OS ------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---- Secrets / keys / runtime artifacts (NEVER commit) ------------------
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx
*.crt
*.csr
.demo_keys/
.secrets/

# ---- Docker / runtime data ----------------------------------------------
# docker-compose named volumes are managed by docker; bind-mount data dirs
# (if any) live under ./data/ and must never be committed.
data/
*.sqlite
*.sqlite3
*.db
*.db-journal

# ---- Logs ----------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Build / packaging output -------------------------------------------
*.tar
*.tar.gz
*.tgz

# ---- Project-specific ----------------------------------------------------
# Bootstrapped agent keys (generated by scripts/agent_entrypoint.sh on first
# container start; lives in docker-managed volumes, but guard against accidental
# bind-mount into the tree).
keys/

# Pyc generated by docker builds that escaped the COPY filter.
**/__pycache__/

# Local override of compose
docker-compose.override.yml

# Personal drafts / notes — never push
personal/
