GW_HOST=0.0.0.0
GW_PORT=8080
GW_LOG_LEVEL=info

GW_IDP_JWKS_URL=https://idp.local:8443/jwks
GW_IDP_ISSUER=https://idp.local

GW_OPA_URL=http://opa.local:8181/v1/data/agent/authz
GW_OPA_TIMEOUT_MS=5

GW_REDIS_URL=redis://redis.local:6379/0
GW_REDIS_PASSWORD=

GW_ADMIN_TOKEN=changeme-replace-in-prod

GW_MTLS_ENABLED=false
GW_MTLS_CERT=/certs/gw.crt
GW_MTLS_KEY=/certs/gw.key
GW_MTLS_CA=/certs/ca.crt

GW_ANTHROPIC_API_KEY=

GW_DELEGATION_MAX_DEPTH=4
GW_DPOP_MAX_IAT_SKEW=60
GW_DPOP_JTI_TTL=120

GW_RATE_LIMIT_CAPACITY=100
GW_RATE_LIMIT_REFILL_RATE=10.0

GW_AUDIT_DB_PATH=audit.db
GW_AUDIT_FLUSH_INTERVAL_MS=100
GW_AUDIT_FLUSH_BATCH_SIZE=50

GW_REGISTRY_PATH=registry.yaml
GW_POLICY_VERSION=v1.0.0
