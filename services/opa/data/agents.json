{
  "agents": {
    "doc_assistant": {
      "role": "orchestrator",
      "capabilities": [
        {
          "action": "feishu.doc.write",
          "resource_pattern": "doc_token:*",
          "constraints": { "max_calls_per_minute": 30 }
        },
        {
          "action": "feishu.bitable.read",
          "resource_pattern": "app_token:*/table:*",
          "constraints": { "max_calls_per_minute": 60 }
        }
      ],
      "delegation": {
        "accept_from": ["user"],
        "max_depth": 1
      }
    },
    "data_agent": {
      "role": "executor",
      "capabilities": [
        {
          "action": "feishu.bitable.read",
          "resource_pattern": "app_token:*/table:*",
          "constraints": { "max_calls_per_minute": 60 }
        },
        {
          "action": "feishu.contact.read",
          "resource_pattern": "contact:*",
          "constraints": { "max_calls_per_minute": 30 }
        },
        {
          "action": "feishu.calendar.read",
          "resource_pattern": "calendar:*",
          "constraints": { "max_calls_per_minute": 30 }
        }
      ],
      "delegation": {
        "accept_from": ["doc_assistant", "user"],
        "max_depth": 2
      }
    },
    "web_agent": {
      "role": "executor",
      "capabilities": [
        {
          "action": "web.search",
          "resource_pattern": "*",
          "constraints": { "max_calls_per_minute": 10 }
        },
        {
          "action": "web.fetch",
          "resource_pattern": "https://*",
          "constraints": { "max_calls_per_minute": 20 }
        }
      ],
      "delegation": {
        "accept_from": ["doc_assistant", "user"],
        "max_depth": 2
      }
    }
  }
}
